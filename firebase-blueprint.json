{
  "entities": {
    "CropRecommendation": {
      "title": "Crop Recommendation",
      "description": "Stores AI-generated crop recommendations based on farm, soil, and weather data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who requested the recommendation." },
        "farmerName": { "type": "string" },
        "farmName": { "type": "string" },
        "state": { "type": "string" },
        "district": { "type": "string" },
        "village": { "type": "string" },
        "farmArea": { "type": "number" },
        "soilType": { "type": "string" },
        "soilPh": { "type": "number" },
        "nitrogen": { "type": "number" },
        "phosphorus": { "type": "number" },
        "potassium": { "type": "number" },
        "organicCarbon": { "type": "number" },
        "season": { "type": "string" },
        "avgTemperature": { "type": "number" },
        "rainfall": { "type": "number" },
        "humidity": { "type": "number" },
        "irrigationAvailable": { "type": "boolean" },
        "preferredCropType": { "type": "string" },
        "budget": { "type": "number" },
        "waterAvailability": { "type": "string" },
        "organicFarming": { "type": "boolean" },
        "previousCrop": { "type": "string" },
        "farmingExperience": { "type": "string" },
        "recommendedCrop": { "type": "string" },
        "confidenceScore": { "type": "number" },
        "reason": { "type": "string" },
        "expectedYield": { "type": "string" },
        "estimatedProfit": { "type": "number" },
        "cropDuration": { "type": "string" },
        "waterRequirement": { "type": "string" },
        "fertilizerSuggestion": { "type": "string" },
        "pestRiskLevel": { "type": "string" },
        "suitableSeason": { "type": "string" },
        "estimatedHarvestDate": { "type": "string" },
        "marketDemand": { "type": "string" },
        "difficultyLevel": { "type": "string" },
        "sustainabilityScore": { "type": "number" },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "profit": { "type": "number" },
              "yield": { "type": "string" },
              "waterRequirement": { "type": "string" },
              "duration": { "type": "string" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "recommendedCrop", "createdAt"]
    }
  },
  "firestore": {
    "cropRecommendations": {
      "schema": "CropRecommendation",
      "description": "Collection of all crop recommendations generated by the AI."
    }
  }
}
